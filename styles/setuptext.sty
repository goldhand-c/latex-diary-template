% % --- STYLE 1: The Notebook (Lined) ---
\newlength{\notebooklineskip}
\setlength{\notebooklineskip}{\baselineskip}
\newcommand{\enableNotebook}{
  \backgroundsetup{ % 22 lines
    scale=1, angle=0, opacity=1,
    contents={
        \begin{tikzpicture}[remember picture, overlay]
          \draw[blue!35]   (current page.north west) ++(-5.71cm, 12*\notebooklineskip - 3.03cm) -- ++(\paperwidth,0);
          \foreach \i in {-11,...,10} {
              \draw[blue!20] (current page.north west) ++(-5.71cm,-\i*\notebooklineskip - 3.03cm) -- ++(\paperwidth,0);
            }
          \draw[blue!35]   (current page.north west) ++(-5.71cm,-11*\notebooklineskip - 3.03cm) -- ++(\paperwidth,0);
          \draw[red!30, thick] (current page.north west) ++(-2.65cm,8.5cm) -- ++(0,-24cm);
        \end{tikzpicture}
      }
  }
}

