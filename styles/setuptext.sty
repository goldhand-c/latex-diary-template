% -------- GRAPHICS --------
\RequirePackage{graphicx, float} % Insert pictures
\RequirePackage{amsmath}


% -------- COLOR --------
\RequirePackage[dvipsnames]{xcolor}
\color{blue!10!black}


% -------- REFERENCE --------
