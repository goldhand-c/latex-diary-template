\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{setuptext}

% -------- SPACING --------
\raggedbottom % no vertical justification
\RequirePackage{calc} % setcounter / setlength / widthof
\RequirePackage{indentfirst} % force indent
% (must use before polyglossia/ragged2e)

\RequirePackage[normalem]{ulem} % uline uuline uwave sout xout dashuline dotuline

\RequirePackage{setspace} % begin spacing 1.5
\setstretch{1.618}         % line spacing
\setlength\footskip{40pt}    % space before base of footer
\setlength\parskip{\baselineskip} % paragraph spacing
\setlength\parindent{0.75cm} % indent length


% -------- PAGE --------
\RequirePackage{lipsum, ragged2e} % minipage / raggedright

\RequirePackage{multicol} % page columns \begin{multicols*}{2} \columnbreak
