% \setlength{\columnseprule}{0.6pt} % thickness of vertical rule

\RequirePackage{fancyhdr}   % header
\pagestyle{fancy}           % activate header
% \fancyhfoffset[L,R]{1cm}  % expend outside text area
\renewcommand{\headrulewidth}{0pt} % width of header line
% \renewcommand{\footrulewidth}{0.5pt} % width of footer line
% \renewcommand{\headrule}{{\color{black!80}\hrule width\headwidth height\headrulewidth \vskip-\headrulewidth}} % color

\RequirePackage{titling}    % call title author date

\RequirePackage{pdfpages} % \includepdf[pages=-]{All.pdf}


% -------- FONTS --------
