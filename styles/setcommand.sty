\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{setcommand}

% This is for defining custom control sequences

% -------- OLD STYLE NUM --------
% Use \oldstynum for counter
% Use \oldnumber for manual input
\def\oldstynum#1{\expandafter\oldnumber\csname c@#1\endcsname}
\def\oldnumber#1{%
    \olddigits{\number#1}%
}
\def\olddigits#1{\expandafter\oldigits #1@ }
\def\oldigits#1{%
    \ifx @#1% olen terminate
    \else
        \ifx0#1\scalebox{0.95}[0.85]0\else%
            \ifx1#1\scalebox{0.95}[0.85]1\else%
                \ifx2#1\scalebox{0.95}[0.85]2\else%
                    \ifx3#1\raisebox{-0.4ex}{3}\else%
                        \ifx4#1\raisebox{-0.4ex}{4}\else%
                            \ifx5#1\raisebox{-0.4ex}{5}\else%
                                \ifx6#1{6}\else%
                                    \ifx7#1\raisebox{-0.4ex}{7}\else%
                                        \ifx8#1{8}\else%
                                            \ifx9#1\raisebox{-0.4ex}{9}\else%
                                                #1\fi\fi\fi\fi\fi\fi\fi\fi\fi\fi
        \expandafter\oldigits
    \fi
}

\renewcommand{\thepage}{\oldstynum{page}}
% \renewcommand{\thesection}{\oldstynum{section}\!\!}
