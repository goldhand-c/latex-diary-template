% -------- TIME --------
\newcommand{\mytime}{%
    \count255=\time
    \divide\count255 by 60
    \the\count255.% Hour
    \count255=\time
    \count254=\count255
    \divide\count254 by 60
    \multiply\count254 by 60
    \advance\count255 by -\count254
    \ifnum\count255<10 0\fi\the\count255% Minute (with leading zero)
}

\RequirePackage{pgfcalendar} % day utilities

% Day note
\def\dayof#1{\splitdate#1\relax}
\def\splitdate#1/#2/#3\relax{
    \newcount\dow%
    \pgfcalendardatetojulian{#3-#2-#1}{\dow}%
    \pgfcalendarjuliantoweekday{\dow}{\dow}%
    \ifcase\dow  Monday\or  Tuesday\or  Wednesday\or  Thursday\or  Friday\or  Saturday\else  Sunday\fi
}

\newcommand{\pagetarget}[2]{%
    \phantomsection%
    \label{#1}%
    \hypertarget{#1}{#2}%
}

\newcommand{\daynote}[2][]{%
    \sidenote[\hspace*{-0.6em}]{%
        \oldnumber{#2} \\ \dayof{#2} #1}%
    \vadjust{\vspace{-2\notebooklineskip}}\par%
}

\newcommand{\monthnote}[1]{%
    \sidenote[\hspace*{-1.3em}]{%
        \nolinebreak%
        \raisebox{0.5ex}{\MiniPostIt*[yellow]{\raisebox{-0.5ex}{\bfseries\ \pagetarget{#1}{#1}}}}}%
    \vadjust{\vskip-1\baselineskip}%
}

\newcommand{\xdaynote}[1]{\phantom{}\hfill --- {\itshape #1}}


